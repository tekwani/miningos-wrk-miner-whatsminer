  "description": "MiningOS Worker Miner Whatsminer",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/miningos-wrk-miner-whatsminer.git"
  },
  "homepage": "https://github.com/tetherto/miningos-wrk-miner-whatsminer#readme",
  "bugs": {
    "url": "https://github.com/tetherto/miningos-wrk-miner-whatsminer/issues"
  },  
  "engines": {
    "node": ">=20"
  },
  "files": [
    "worker.js",
    "workers/",
    "mock/"
  ],
  "main": "worker.js",  
  "type": "commonjs",
  "bin": {
    "miningos-wrk-miner-whatsminer": "worker.js"
  },
  "scripts": {
